{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Pipeline: Debug",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "Tests: Debug All",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v", "--tb=short", "--no-header"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "Module: Debug Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "Module: Debug Specific",
      "type": "debugpy",
      "request": "launch",
      "module": "mediapipe_seguranca.${input:moduleName}",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    }
  ],
  "inputs": [
    {
      "id": "moduleName",
      "type": "pickString",
      "description": "Select module to debug",
      "options": [
        "pipeline",
        "video_io",
        "mediapipe_extract",
        "feature_engineering",
        "tracking_features",
        "train_unsupervised",
        "train_supervised",
        "evaluate"
      ],
      "default": "pipeline"
    }
  ]
}
